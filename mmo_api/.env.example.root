# OpenAI Whisper runs locally; no API key is required for transcription.
# NVIDIA API translation credentials
NVIDIA_API_KEY=your-nvidia-api-key
# Optional: explicitly pin the primary translation model
NVIDIA_MODEL=nvidia/llama2-70b-chat
# Optional: comma-separated fallback chain when a model is unavailable or out of quota
# NVIDIA_MODELS=nvidia/llama2-70b-chat,meta/llama2-70b-chat-hf
# Optional: custom FFmpeg path if not in PATH
FFMPEG_PATH=ffmpeg

# NVIDIA Translation Configuration
# Optional: API endpoint (defaults to NVIDIA's official endpoint)
# NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
# Optional: Request timeout in seconds (default: 60)
# NVIDIA_API_TIMEOUT=60
# Optional: LLM temperature for translation (0.0-1.0, default: 0.3, lower = more deterministic)
# NVIDIA_TEMPERATURE=0.3
# Optional: Maximum tokens in model response (default: 2048)
# NVIDIA_MAX_TOKENS=2048

# Text Processing Configuration
# Optional: Transcript chunk size for translation (default: 1500 chars)
# TRANSCRIPT_CHUNK_SIZE=1500
# Optional: Subtitle batch chunk size (default: 1200 chars)
# SUBTITLE_BATCH_CHUNK_SIZE=1200
# Optional: Max retry attempts per model on quota/rate limit (default: 2)
# MAX_QUOTA_RETRIES=2
# VoxCPM2 TTS Configuration
# Model variant: openbmb/VoxCPM2 (recommended), openbmb/VoxCPM-0.6B (faster, lower quality)
VOXCPM_MODEL=openbmb/VoxCPM2
# Optional: Device for inference (auto, cpu, cuda, cuda:0, mps)
VOXCPM_DEVICE=auto
# Optional: Classifier-free guidance scale (0.0-3.0, higher = more faithful to description)
VOXCPM_CFG_VALUE=2.0
# Optional: Inference timesteps (1-20, higher = better quality but slower)
VOXCPM_INFERENCE_TIMESTEPS=10
# Optional: Load denoiser for ultra-high quality (memory intensive)
VOXCPM_LOAD_DENOISER=false
# Optional Khmer subtitle styling for burned-in captions
KHMER_SUBTITLE_FONT=Leelawadee UI
KHMER_SUBTITLE_FONT_SIZE=22
KHMER_SUBTITLE_MARGIN_V=28
# Output locations
OUTPUT_DIR=output
TEMP_DIR=temp_assets
