# OpenAI Whisper should be local model; there is no API key by default
# GOOGLE API (Gemini + TTS) keys
GOOGLE_APPLICATION_CREDENTIALS=path/to/your-service-account.json
GOOGLE_PROJECT_ID=your-google-project-id
# Optional: custom ffmpeg path if not in PATH
FFMPEG_PATH=ffmpeg
# Environment
OUTPUT_DIR=output
tEMP_DIR=temp_assets